{
  "name": "email-sender-app",
  "version": "1.0.0",
  "description": "Simple Node.js app to send emails using email-templates and nodemailer",
  "main": "dist/main.js",
  "scripts": {
    "start:dev": "ts-node src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js"
  },
  "keywords": [
    "email",
    "nodemailer",
    "email-templates",
    "mailpit"
  ],
  "author": "Kasir Barati",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">= 10.28.2",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": ">= 24.13 < 25",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@10.28.2",
  "license": "ISC",
  "dependencies": {
    "email-templates": "^12.0.1",
    "nodemailer": "^6.9.16",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "@types/email-templates": "^10.0.4",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
